
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Voters can be created by any authenticated user.
    // They can only read/update their own data.
    match /voters/{voterId} {
      allow create: if isSignedIn();
      allow get, update: if isSignedIn() && isOwner(voterId);
      allow list, delete: if false;
    }

    // Blocks are publicly readable.
    // Writes to blocks (and their votes subcollection) are handled
    // through server actions, so direct client creation is denied.
    match /blocks/{blockId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      // Votes within a block are also publicly readable.
      match /votes/{voteId} {
        allow get, list: if true;
        allow create, update, delete: if false;
      }
    }

    // Fraudulent activity logs are write-only by the backend.
    // No client should be able to read or write these directly.
    match /fraudulent_activities/{fraudulentActivityId} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}
